	local num = tonumber(PowerInput.Text)
	if num and num >= 0.001 and num <= 20 then gfxPower = num else PowerInput.Text = tostring(gfxPower) end
	if active then applyWorldGFX() if LocalPlayer.Character then applyCharacterGFX(LocalPlayer.Character) end end
end)

