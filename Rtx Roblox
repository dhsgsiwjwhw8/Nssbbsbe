local function applySky()
	for _, v in pairs(Lighting:GetChildren()) do if v:IsA("Sky") then v:Destroy() end end
	local sky = Instance.new("Sky", Lighting)
	sky.SkyboxBk = "rbxassetid://14213745265" sky.SkyboxDn = "rbxassetid://14213745597"
	sky.SkyboxFt = "rbxassetid://14213746014" sky.SkyboxLf = "rbxassetid://14213746371"
	sky.SkyboxRt = "rbxassetid://14213746816" sky.SkyboxUp = "rbxassetid://14213747447"
	sky.SunTextureId = "rbxassetid://0" sky.MoonTextureId = "rbxassetid://0"
end

local function updatePostProcessing()
	local bloom = Lighting:FindFirstChildOfClass("BloomEffect") or Instance.new("BloomEffect", Lighting)
	bloom.Intensity = 0.25 * gfxPower bloom.Size = 5.5 bloom.Threshold = 0.83
	
	local cc = Lighting:FindFirstChildOfClass("ColorCorrectionEffect") or Instance.new("ColorCorrectionEffect", Lighting)
	cc.Brightness = 0.03 cc.Contrast = 0.07 * gfxPower cc.Saturation = 0.28 * gfxPower
	cc.TintColor = Color3.fromRGB(255, 240, 245)
	
	local atmos = Lighting:FindFirstChildOfClass("Atmosphere") or Instance.new("Atmosphere", Lighting)
	atmos.Density = 0.24 atmos.Offset = 0.12 atmos.Color = Color3.fromRGB(242, 246, 255) atmos.Decay = Color3.fromRGB(255, 232, 241) atmos.Glare = 0.22 atmos.Haze = 1.1
end

local function applyWorldGFX()
	if not active then return end
	Lighting.Ambient = Color3.fromRGB(155, 155, 160)
	Lighting.OutdoorAmbient = Color3.fromRGB(195, 195, 200)
	Lighting.Brightness = brightnessPower
	updatePostProcessing()
	
	for _, part in pairs(workspace:GetDescendants()) do
		if part:IsA("BasePart") and not part:IsDescendantOf(LocalPlayer.Character or workspace) then
			if not originalMaterials[part] then originalMaterials[part] = part.Material originalReflectance[part] = part.Reflectance end
			if part.Size.Y <= 3 or part.Name:lower():find("floor") or part.Name:lower():find("ground") or part.Material == Enum.Material.Glass or part.Material == Enum.Material.SmoothPlastic then
				part.Material = Enum.Material.Glass
				part.Reflectance = math.clamp(0.8 * gfxPower, 0, 0.98)
				for _, child in pairs(part:GetChildren()) do
					if child:IsA("Texture") or child:IsA("Decal") then
						if not hiddenTextures[child] then hiddenTextures[child] = child.Transparency end
						child.Transparency = 1
					end
				end
			end
		end
	end
end

local function applyCharacterGFX(char)
	if not active or not char then return end
	for _, part in pairs(char:GetChildren()) do
		if part:IsA("BasePart") then
			if part.Name == "Head" then
				part.Material = Enum.Material.SmoothPlastic
				part.Reflectance = 0
			else
				part.Material = Enum.Material.Glass
				part.Reflectance = math.clamp(0.3 * gfxPower, 0, 0.7)
			end
		elseif part:IsA("Accessory") and part:FindFirstChild("Handle") then
			if part.Name:lower():find("face") or part.Name:lower():find("makeup") or part.Name:lower():find("head") then
				part.Handle.Material = Enum.Material.SmoothPlastic
				part.Handle.Reflectance = 0
			else
				part.Handle.Material = Enum.Material.Glass
				part.Handle.Reflectance = math.clamp(0.25 * gfxPower, 0, 0.6)
			end
		end
	end
end

local function clearGFX()
	for _, v in pairs(Lighting:GetChildren()) do if v:IsA("PostEffect") or v:IsA("Sky") or v:IsA("Atmosphere") then v:Destroy() end end
	for part, mat in pairs(originalMaterials) do if part and part.Parent then part.Material = mat part.Reflectance = originalReflectance[part] end end
	for texture, trans in pairs(hiddenTextures) do if texture and texture.Parent then texture.Transparency = trans end end
	
	local char = LocalPlayer.Character
	if char then 
		for _, part in pairs(char:GetDescendants()) do 
			if part:IsA("BasePart") then part.Material = Enum.Material.Plastic part.Reflectance = 0 end 
		end 
	end
	table.clear(originalMaterials) table.clear(originalReflectance) table.clear(hiddenTextures)
end

