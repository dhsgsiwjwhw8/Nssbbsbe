--================== دوال الفقاعات (فقاعة واحدة لكل لاعب) ==================--
local playerBubbles = {}  -- key = character (أو اسم اللاعب), value = كائن الفقاعة

local function createBubble(character, msg)
	if not character or not character:FindFirstChild("Head") then return end

	-- إذا كان هناك فقاعة سابقة لهذا اللاعب، نحذفها
	local key = character   -- نستخدم الكائن نفسه كمفتاح (أو character.Name)
	if playerBubbles[key] then
		local old = playerBubbles[key]
		if old and old.Parent then
			old:Destroy()
		end
		playerBubbles[key] = nil
	end

	-- إنشاء الفقاعة الجديدة
	local bubble = Instance.new("BillboardGui")
	bubble.Adornee = character.Head
	bubble.Size = UDim2.new(0, math.clamp(#msg * 8 + 30, 90, 250), 0, 40)
	bubble.StudsOffset = Vector3.new(0, 3, 0)
	bubble.AlwaysOnTop = true
	bubble.Parent = character.Head

	local bg = Instance.new("Frame", bubble)
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
	bg.BackgroundTransparency = 0.15
	Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 12)

	local txt = Instance.new("TextLabel", bg)
	txt.Size = UDim2.new(1, -10, 1, -8)
	txt.Position = UDim2.new(0, 5, 0, 4)
	txt.BackgroundTransparency = 1
	txt.Text = msg
	txt.TextColor3 = Color3.fromRGB(30, 30, 30)
	txt.TextSize = 13
	txt.Font = Enum.Font.Gotham
	txt.TextWrapped = true
	txt.TextXAlignment = Enum.TextXAlignment.Center

	-- تخزين الفقاعة الجديدة
	playerBubbles[key] = bubble

	-- مؤقت لحذفها بعد 7 ثوانٍ
	task.delay(7, function()
		if playerBubbles[key] == bubble then
			if bubble and bubble.Parent then
				bubble:Destroy()
			end
			playerBubbles[key] = nil
		end
	end)
end

--================== دوال الرسائل ==================--
local function addMessage(name, msg, color)
	local frame = Instance.new("Frame", scroll)
	frame.Size = UDim2.new(1, 0, 0, 0)
	frame.AutomaticSize = Enum.AutomaticSize.Y
	frame.BackgroundTransparency = 1

	local label = Instance.new("TextLabel", frame)
	label.Size = UDim2.new(1, -4, 0, 0)
	label.AutomaticSize = Enum.AutomaticSize.Y
	label.Position = UDim2.new(0, 2, 0, 0)
	label.BackgroundTransparency = 1
	label.RichText = true
	local hex = string.format("#%02x%02x%02x", color.R*255, color.G*255, color.B*255)
	label.Text = string.format("<font color='%s'><b>%s</b></font>: %s", hex, name, msg)
	label.TextColor3 = Color3.new(1, 1, 1)
	label.TextSize = 13
	label.Font = Enum.Font.Gotham
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left

	task.defer(function()
		scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
	end)
end

--================== الاستقبال ==================--
GlobalRemote.OnClientEvent:Connect(function(sender, msg)
	addMessage(sender.Name .. " [عام]", msg, Color3.fromRGB(255, 220, 100))
	if sender.Character then createBubble(sender.Character, msg) end
end)

LocalRemote.OnClientEvent:Connect(function(sender, msg)
	addMessage(sender.Name .. " [خاص]", msg, Color3.fromRGB(100, 255, 100))
	if sender.Character then createBubble(sender.Character, msg) end
end)

--================== الإرسال ==================--
local function send()
	local msg = textBox.Text
	if msg == "" then return end
	if currentMode == "Global" then
		GlobalRemote:FireServer(msg)
		addMessage(player.Name .. " (أنت - عام)", msg, Color3.fromRGB(0, 180, 255))
	else
		LocalRemote:FireServer(msg)
		addMessage(player.Name .. " (أنت - خاص)", msg, Color3.fromRGB(0, 255, 120))
	end
	if player.Character then createBubble(player.Character, msg) end
	textBox.Text = ""
end

sendBtn.MouseButton1Click:Connect(send)
textBox.FocusLost:Connect(function(enter)
	if enter then send() end
end)

addMessage("النظام", "✓ فقاعة واحدة لكل لاعب (تستبدل)", Color3.fromRGB(255, 255, 0))
